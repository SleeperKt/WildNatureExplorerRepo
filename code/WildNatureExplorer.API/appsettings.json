{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "ChatLlm": {
    "BaseUrl": "https://api.groq.com/openai/v1/",
    "ApiKey": "",
    "PrimaryModel": "llama-3.1-8b-instant",
    "FallbackModel": "llama-3.3-70b-versatile",
    "ChatTemperature": 0.38,
    "ChatMaxTokens": 320,
    "StructuredTemperature": 0.28,
    "StructuredMaxTokens": 450,
    "RequestTimeoutSeconds": 55
  },

  "AiInference": {
    "MaxUserMessageChars": 4096
  },

  "AiKnowledge": {
    "ChunksFileRelativePath": "docs/ai/knowledge_chunks.json",
    "MaxInjectedContextChars": 1400
  },

  "AiRateLimit": {
    "PermitLimit": 60,
    "WindowMinutes": 1,
    "SegmentsPerWindow": 6
  }
}