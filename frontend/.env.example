# Leave empty for local dev: the browser calls `/api/...` and Vite proxies to the backend (see vite.config.js).
# For production Docker/Azure builds, CI sets VITE_API_URL to your API App Service URL (https://your-api.azurewebsites.net).
VITE_API_URL=

# Optional: where Vite should proxy `/api` when you do not run the API on localhost:5000.
# VITE_DEV_PROXY_TARGET=http://localhost:5000

# Optional: short-lived tunnel base URL for manual debugging only — never use in deployed images.
# VITE_DEV_TUNNEL_API_URL=
