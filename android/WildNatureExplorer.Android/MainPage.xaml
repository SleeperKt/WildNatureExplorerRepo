<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WildNatureExplorer.Android.MainPage">

	<Grid RowDefinitions="*">
		<Grid Grid.Row="0">
			<WebView
				x:Name="AppWebView"
				HorizontalOptions="Fill"
				VerticalOptions="Fill"
				Navigated="OnWebViewNavigated" />
		</Grid>

		<!-- Overlay setup panel that hides when ready -->
		<VerticalStackLayout
			x:Name="SetupPanel"
			Spacing="12"
			Padding="20"
			Grid.Row="0"
			BackgroundColor="#F8F9FA"
			VerticalOptions="Center"
			Margin="20"
			IsVisible="False">
			<Label
				Text="WildNatureExplorer Android"
				FontSize="20"
				FontAttributes="Bold"
				HorizontalOptions="Center" />

			<Label Text="Web URL (ngrok frontend)" FontAttributes="Bold" />
			<Entry
				x:Name="WebUrlEntry"
				Keyboard="Url"
				Placeholder="https://xxxx.ngrok-free.app/"
				TextChanged="OnUrlTextChanged" />

			<Label Text="API URL (ngrok backend)" FontAttributes="Bold" />
			<Entry
				x:Name="ApiUrlEntry"
				Keyboard="Url"
				Placeholder="https://xxxx.ngrok-free.app"
				TextChanged="OnUrlTextChanged" />

			<Label x:Name="NotificationsStatusLabel" Text="Notifications: checking..." />
			<Label x:Name="LocationStatusLabel" Text="Location: checking..." />
			<Label x:Name="BackgroundLocationStatusLabel" Text="Background location: checking..." />

			<Button
				Text="Enable Permissions &amp; Launch"
				Clicked="OnRequestPermissionsClicked"
				HorizontalOptions="Fill" />

			<Label
				Text="You must grant permissions for Danger mode notifications to work even when the app is sleeping."
				FontSize="12"
				TextColor="Gray" />
		</VerticalStackLayout>
	</Grid>
</ContentPage>
