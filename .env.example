ASPNETCORE_ENVIRONMENT=Development
PORT=5000

# Published frontend port when using docker-compose (nginx → SPA + `/api` proxy to API container).
WEB_PORT=5174

# Comma-separated browser origins allowed by the API (Azure: include https://your-frontend.azurewebsites.net).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Database
DB_HOST=example-db-host
DB_PORT=5432
DB_NAME=example-db-name
DB_USER=example-db-user
DB_PASSWORD=example-db-password

ADMIN_EMAIL=exampleadminemail@gmail.com

# JWT
JWT_KEY=example-jwt-key
HF_API_KEY=example-hf-api-key
GROQ_API_KEY=example-groq-api-key
JWT_ISSUER=example-jwt-issuer
JWT_AUDIENCE=example-jwt-audience
ANIMALDETECT_API_KEY=example-animaldetect-api-key

# GitHub Actions (set as repository secrets):
# ANIMALDETECT_API_KEY, WNE_API_PUBLIC_BASE_URL (API https base, no trailing slash),
# optional WNE_FRONTEND_PUBLIC_URL (SPA https base for post-deploy curl check; omit to skip),
# CORS_ORIGINS,
# AZURE_WEBAPP_API_NAME, AZURE_WEBAPP_FRONTEND_NAME, plus existing JWT/DB/Azure/Docker Hub secrets.
