# Copy this file to `.env` in the repository root (next to docker-compose.yml).
# Do not commit real secrets — `.env` is gitignored.

# --- PostgreSQL / PostGIS (`db` service in Compose) ---
DB_USER=wne_user
DB_PASSWORD=ChangeMe_LocalDev_Only
DB_NAME=wild_nature_explorer
# In Compose, use the DB service hostname from docker-compose.yml:
DB_HOST=db
DB_PORT=5432

# --- Published ports on the host ---
# API listens on 5000 inside the container; PORT is the host mapping:
PORT=5000
# Web (nginx + built SPA); compose defaults WEB_PORT to 5174:
WEB_PORT=5174

# --- JWT (use a long random secret in production) ---
JWT_KEY=LocalDevelopmentJwtSigningKey_MinimumLengthRecommended32CharsOrMore
JWT_ISSUER=WildNatureExplorer
JWT_AUDIENCE=WildNatureExplorerUsers

# --- External AI APIs ---
# Non-empty value required for API startup: Groq client registers at boot and fails if empty.
# Use a real key from the Groq console for live requests.
GROQ_API_KEY=replace-with-real-groq-key

# Hugging Face — used for HF-backed recognition (may stay empty until that path runs).
HF_API_KEY=

# Animal Detect — required when calling that provider; may be empty at startup.
ANIMALDETECT_API_KEY=

# --- Other ---
# Admin email (auth/bootstrap logic — see AuthService).
ADMIN_EMAIL=admin@example.com

# Comma-separated CORS origins. If unset, see docker-compose.yml defaults.
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
